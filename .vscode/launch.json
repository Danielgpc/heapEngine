{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Game",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/bin/heap_engine",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "DYLD_LIBRARY_PATH",
          "value": "${workspaceFolder}/lib:$DYLD_LIBRARY_PATH"
        },
        {
          "name": "LD_LIBRARY_PATH",
          "value": "${workspaceFolder}/lib:$LD_LIBRARY_PATH"
        }
      ],
      "externalConsole": false,
      "MIMode": "lldb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build All",
      "miDebuggerPath": "/usr/bin/lldb"
    },
    {
      "name": "Debug Game (gdb)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/bin/heap_engine",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "LD_LIBRARY_PATH",
          "value": "${workspaceFolder}/lib:$LD_LIBRARY_PATH"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build All",
      "miDebuggerPath": "/usr/bin/gdb"
    }
  ]
}